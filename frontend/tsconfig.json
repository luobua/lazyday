{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@lazyday/types": ["./packages/types/src"],
      "@lazyday/types/*": ["./packages/types/src/*"],
      "@lazyday/utils": ["./packages/utils/src"],
      "@lazyday/utils/*": ["./packages/utils/src/*"],
      "@lazyday/api-client": ["./packages/api-client/src"],
      "@lazyday/api-client/*": ["./packages/api-client/src/*"],
      "@lazyday/ui": ["./packages/ui/src"],
      "@lazyday/ui/*": ["./packages/ui/src/*"]
    }
  },
  "references": [
    { "path": "./apps/portal" },
    { "path": "./apps/admin" },
    { "path": "./packages/types" },
    { "path": "./packages/utils" },
    { "path": "./packages/api-client" },
    { "path": "./packages/ui" }
  ]
}
